---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const T = useTranslations('fr');
---

<BaseLayout locale="fr" title={T.nav.contact}>
  <section>
    <div class="container">
      <h1>{T.contact.title}</h1>
      <p class="sub">{T.contact.sub}</p>
      <!-- Replace the src with your Calendly embed URL -->
      <div class="calendly-placeholder">
        <p>[ Intégration Calendly ]</p>
        <p class="hint">Remplacez ce bloc par votre widget Calendly inline.</p>
      </div>
      <p class="email-line">
        {T.contact.email}&nbsp;<a href="mailto:info@seersware.com">info@seersware.com</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    font-size: 2.25rem;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .sub {
    color: var(--text-muted);
    max-width: 540px;
    margin-bottom: 3rem;
    line-height: 1.7;
  }

  .calendly-placeholder {
    border: 1px dashed var(--border);
    border-radius: 8px;
    padding: 4rem 2rem;
    text-align: center;
    max-width: 700px;
    margin-bottom: 2rem;
    color: var(--text-muted);
  }

  .hint {
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  .email-line {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
</style>
