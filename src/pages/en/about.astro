---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const T = useTranslations('en');
---

<BaseLayout locale="en" title={T.nav.about}>
  <section>
    <div class="container">
      <h1>{T.about.title}</h1>
      <p class="body">{T.about.body}</p>
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    font-size: 2.25rem;
    margin-bottom: 2rem;
    letter-spacing: -0.03em;
  }

  .body {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 660px;
    line-height: 1.8;
  }
</style>
