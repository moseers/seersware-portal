---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

const T = useTranslations('en');
---

<BaseLayout locale="en" title={T.nav.services}>
  <section>
    <div class="container">
      <h1>{T.services.title}</h1>
      <div class="list">
        {T.services.offerings.map((s) => (
          <div class="item">
            <h2>{s.title}</h2>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    font-size: 2.25rem;
    margin-bottom: 3rem;
    letter-spacing: -0.03em;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .item {
    border-left: 2px solid var(--accent);
    padding-left: 2rem;
    max-width: 700px;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  p {
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>
