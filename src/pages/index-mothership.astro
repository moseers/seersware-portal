---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const T = useTranslations('fr');
---

<BaseLayout locale="fr">
  <!-- Hero -->
  <section class="hero">
    <div class="parallax-bg" id="parallax-bg" aria-hidden="true"></div>
    <div class="container hero-content">
      <h1>{T.hero.tagline}</h1>
      <p class="sub">{T.hero.sub}</p>
      <a href="/contact" class="btn">{T.hero.cta}</a>
    </div>
  </section>

  <!-- About -->
  <section class="about">
    <div class="container">
      <p class="eyebrow">{T.about.eyebrow}</p>
      <h2>{T.about.title}</h2>
      <p class="about-body">{T.about.body}</p>
    </div>
  </section>

  <!-- Services -->
  <section class="services-preview">
    <div class="container">
      <h2>{T.services.title}</h2>
      <div class="services-grid">
        {T.services.offerings.map((s) => (
          <div class="service-card">
            <h3>{s.title}</h3>
            <p>{s.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Expertise -->
  <section class="expertise">
    <div class="container">
      <h2>{T.expertise.title}</h2>
      <div class="expertise-grid">
        {T.expertise.items.map((item) => (
          <div class="expertise-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="cta-band">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2>{T.cta.title}</h2>
        <p>{T.cta.sub}</p>
      </div>
      <a href="/contact" class="btn btn-lg">{T.cta.btn}</a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 55vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: radial-gradient(ellipse 80% 60% at 50% -10%, color-mix(in srgb, var(--accent) 12%, transparent), transparent);
  }

  .parallax-bg {
    position: absolute;
    inset: -40% 0;
    background-image: url('/paper-plane.jpg');
    background-size: cover;
    background-position: center;
    z-index: 0;
    will-change: transform;
    pointer-events: none;
  }

  .parallax-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(10, 10, 10, 0.65) 0%, rgba(10, 10, 10, 0.8) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    margin-bottom: 1.5rem;
    letter-spacing: -0.03em;
  }

  .sub {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 700px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .btn {
    display: inline-block;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  .btn:hover {
    background: var(--accent-dim);
    text-decoration: none;
  }

  .btn-lg {
    padding: 0.9rem 2.25rem;
    font-size: 1rem;
    white-space: nowrap;
  }

  /* ── About ── */
  .about {
    position: relative;
    background-image: url('/mtl-dusk.jpg');
    background-size: cover;
    background-position: center;
  }

  .about::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 10, 0.72);
  }

  .about .container {
    position: relative;
    z-index: 1;
  }

  .about h2 {
    font-size: 1.75rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .about-body {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 680px;
    line-height: 1.8;
  }

  /* ── Services ── */
  .services-preview {
    background: var(--bg-2);
  }

  .services-preview h2 {
    font-size: 1.75rem;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: var(--bg-3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.75rem;
    transition: border-color 0.15s;
  }

  .service-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
  }

  .service-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
    color: var(--accent);
  }

  .service-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ── Expertise ── */
  .expertise {
    background: var(--bg);
  }

  .expertise h2 {
    font-size: 1.75rem;
    margin-bottom: 2.5rem;
    letter-spacing: -0.02em;
  }

  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .expertise-card {
    padding: 1.5rem;
    border-left: 2px solid var(--accent);
    background: var(--bg-2);
    border-radius: 0 6px 6px 0;
  }

  .expertise-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .expertise-card p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── CTA Band ── */
  .cta-band {
    background: color-mix(in srgb, var(--accent) 8%, var(--bg-2));
    border-top: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .cta-text h2 {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }

  .cta-text p {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 520px;
  }
</style>

<script>
  const bg = document.getElementById('parallax-bg');
  if (bg) {
    window.addEventListener('scroll', () => {
      bg.style.transform = `translateY(${window.scrollY * 0.35}px)`;
    }, { passive: true });
  }
</script>
